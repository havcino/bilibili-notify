{
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"declaration": true,
		"emitDeclarationOnly": true,
		"composite": true,
		"incremental": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"strict": true,
		"experimentalDecorators": true,
		"jsx": "react-jsx",
		"types": ["node"]
	}
}
