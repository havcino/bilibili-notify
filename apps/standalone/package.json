{
	"name": "@bilibili-notify/root",
	"version": "0.0.0",
	"private": true,
	"description": "Root for the bilibili-notify standalone product (Hono server + React dashboard). pnpm sub-workspace; not part of the root yarn workspace.",
	"scripts": {
		"dev": "pnpm -r --parallel --stream dev",
		"dev:server": "pnpm --filter @bilibili-notify/server dev",
		"dev:web": "pnpm --filter @bilibili-notify/web dev",
		"build": "pnpm -r build",
		"typecheck": "pnpm -r typecheck",
		"start": "pnpm --filter @bilibili-notify/server start"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@10.33.4"
}
