{
	"name": "@bilibili-notify/dynamic",
	"version": "0.0.1-alpha.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Akokk0/bilibili-notify"
	},
	"author": {
		"name": "Akokko",
		"email": "admin@akokko.com"
	},
	"description": "平台中立的 Bilibili 动态轮询/过滤/渲染核心（@bilibili-notify/dynamic）",
