{
	"name": "@root/bilibili-notify",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@11.3.0",
	"scripts": {
		"build": "pnpm -r run build && pnpm --filter koishi-plugin-bilibili-notify run build:client",
		"typecheck": "pnpm -r run typecheck",
		"dev": "pnpm -r --filter './packages/*' run build && pnpm -r --filter './packages/*' --filter '@bilibili-notify/server' --filter '@bilibili-notify/web' --parallel --stream run dev",
		"dev:packages": "pnpm -r --filter './packages/*' --parallel --stream run dev",
		"dev:apps": "pnpm --filter @bilibili-notify/server --filter @bilibili-notify/web --parallel --stream run dev",
		"build:apps": "pnpm -r --filter './packages/*' run build && pnpm --filter @bilibili-notify/server --filter @bilibili-notify/web run build",
		"dev:server": "pnpm --filter @bilibili-notify/server run dev",
		"dev:web": "pnpm --filter @bilibili-notify/web run dev",
		"start:server": "pnpm --filter @bilibili-notify/server run start",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"prepare": "lefthook install",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm build && node scripts/publish.mjs",
		"test": "vp test",
		"knip": "knip --files"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/node": "^22.15.21",
		"@voidzero-dev/vite-plus-core": "^0.1.22",
		"knip": "^6.14.1",
		"lefthook": "^1.11.12",
		"typescript": "^5.8.3",
		"vite-plus": "^0.1.22",
		"vitest": "^4.1.6"
	}
}
