{
	"name": "@root/bilibili-notify",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@10.33.4",
	"scripts": {
		"build": "pnpm -r run build && pnpm --filter koishi-plugin-bilibili-notify run build:client",
		"typecheck": "pnpm -r run typecheck",
		"dev:apps": "pnpm --filter @bilibili-notify/server --filter @bilibili-notify/web --parallel --stream run dev",
		"dev:server": "pnpm --filter @bilibili-notify/server run dev",
		"dev:web": "pnpm --filter @bilibili-notify/web run dev",
		"start:server": "pnpm --filter @bilibili-notify/server run start",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"prepare": "lefthook install",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm build && changeset publish",
		"test": "vitest run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@koishijs/client": "^5.30.11",
		"@koishijs/plugin-console": "^5.30.11",
		"@types/node": "^22.15.21",
		"koishi": "^4.18.11",
		"lefthook": "^1.11.12",
		"tsdown": "^0.21.7",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4"
	}
}
