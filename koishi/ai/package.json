{
	"name": "koishi-plugin-bilibili-notify-ai",
	"version": "2.0.0-alpha.2",
	"repository": {
		"type": "git",
		"url": "https://github.com/Akokk0/bilibili-notify"
	},
	"author": {
		"name": "Akokko",
		"email": "admin@akokko.com"
	},
	"description": "Bilibili Notify AI 增强插件（bilibili-notify 可选插件）",
	"type": "module",
	"files": [
		"lib"
	],
	"main": "./lib/index.cjs",
	"types": "./lib/index.d.cts",
	"exports": {
		".": {
			"import": "./lib/index.mjs",
			"require": "./lib/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"license": "MIT",
	"keywords": [
		"chatbot",
		"koishi",
		"plugin",
		"bilibili",
		"bilibili-notify",
		"ai"
	],
	"scripts": {
		"build": "vp pack",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@bilibili-notify/ai": "workspace:^",
		"@bilibili-notify/api": "workspace:^",
		"@bilibili-notify/internal": "workspace:^",
		"@bilibili-notify/koishi-runtime": "workspace:^"
	},
	"devDependencies": {
		"@koishijs/plugin-help": "^2.4.6",
		"koishi-plugin-bilibili-notify": "workspace:^"
	},
	"peerDependencies": {
		"koishi": "^4.18.11",
		"koishi-plugin-bilibili-notify": "workspace:^"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"koishi": {
		"service": {
			"required": [
				"bilibili-notify"
			]
		},
		"description": {
			"zh": "Bilibili Notify AI 增强插件"
		}
	},
	"module": "./lib/index.mjs",
	"inlinedDependencies": {
		"@standard-schema/spec": "1.1.0",
		"cosmokit": "1.8.1",
		"schemastery": "3.18.0"
	}
}
