{
	"name": "koishi-plugin-bilibili-notify-image",
	"version": "1.0.0-alpha.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Akokk0/bilibili-notify"
	},
	"author": {
		"name": "Akokko",
		"email": "admin@akokko.com"
	},
	"description": "Bilibili 通知图片渲染插件（bilibili-notify 可选插件）",
	"type": "module",
	"files": [
		"lib"
	],
	"license": "MIT",
	"keywords": [
		"chatbot",
		"koishi",
		"plugin",
		"bilibili",
		"bilibili-notify"
	],
	"scripts": {
		"build": "vp pack",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@bilibili-notify/image": "workspace:^",
		"@bilibili-notify/internal": "workspace:^",
		"@bilibili-notify/koishi-runtime": "workspace:^"
	},
	"peerDependencies": {
		"koishi": "^4.18.11",
		"koishi-plugin-puppeteer": "*"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"koishi": {
		"service": {
			"required": [
				"puppeteer"
			],
			"provides": [
				"bilibili-notify-image"
			]
		},
		"description": {
			"zh": "Bilibili 通知图片渲染插件"
		}
	},
	"main": "./lib/index.cjs",
	"types": "./lib/index.d.cts",
	"exports": {
		".": {
			"import": "./lib/index.mjs",
			"require": "./lib/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"inlinedDependencies": {
		"@standard-schema/spec": "1.1.0",
		"cosmokit": "1.8.1",
		"schemastery": "3.18.0"
	},
	"module": "./lib/index.mjs"
}
